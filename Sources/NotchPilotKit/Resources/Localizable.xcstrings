            "state": "translated",
            "value": "桌面底部歌词卡片"
          }
        }
      }
    },
    "desktopLyricsCardDetail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show the current and next lyric at the bottom of the active screen."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在当前活跃屏幕底部显示当前歌词与下一句。"
          }
        }
      }
    },
    "blockHTTPLyricsSources": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Block HTTP Lyrics Sources"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "不使用 HTTP 歌词源"
          }
        }
      }
    },
    "blockHTTPLyricsSourcesDetail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When enabled, searches use HTTPS-only providers. Leave it off to include more lyric sources, some of which use HTTP."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "开启后只使用 HTTPS 歌词源；关闭时会使用更多歌词源，其中部分通过 HTTP 查询。"
          }
        }
      }
    },
    "devinIntegration": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Devin Integration"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Devin 集成"
          }
        }
      }
    },
    "devinIntegrationDetail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Devin Local reuses Claude Code's hook configuration, so no separate install is required. Complete the integration on the Claude tab first."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Devin Local 会复用 Claude Code 的 Hook 配置，因此无需单独安装。请先在「Claude」标签里完成集成。"
          }
        }
      }
    },
    "diskThresholdTitle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Disk Free Trigger"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "磁盘剩余触发线"
          }
        }
      }
    },
    "displayApprovalSneakNotifications": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Show Claude / Codex Approval Popups"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示 Claude / Codex 审批弹窗"
          }
        }
      }
    },
    "displayApprovalSneakNotificationsDetail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When off, approval prompts will not pop up automatically. Running session previews (with timer) are still shown."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭后审批不会主动弹出，但运行中的会话预览（含计时）仍会显示。"
          }
        }
      }
    },
    "enableClaudePlugin": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Claude Plugin"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用 Claude 插件"
          }
        }
      }
    },
    "enableClaudePluginDetail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When off, Claude hooks are ignored and Claude sessions are removed from Notch."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭后不会处理 Claude Hook，也不会在 Notch 中显示 Claude 会话。"
          }
        }
      }
    },
    "enableCodexPlugin": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Codex Plugin"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用 Codex 插件"
          }
        }
      }
    },
    "enableCodexPluginDetail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When off, Codex Desktop sessions are not monitored and Codex is removed from Notch."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭后不再监听 Codex Desktop 会话，也不会出现在 Notch。"
          }
        }
      }
    },
    "enableDevinPlugin": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Devin Plugin"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用 Devin 插件"
          }
        }
      }
    },
    "enableDevinPluginDetail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When off, Devin Local tool-use events are ignored and Devin sessions are removed from Notch."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭后不会处理 Devin Local 的工具调用事件，也不会在 Notch 中显示 Devin 会话。"
          }
        }
      }
    },
    "enableMediaPlugin": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable Media Plugin"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用媒体插件"
