    "avoidDuplicateSoundsDetail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "NotchPilot cannot directly change Claude or Codex system notification sounds. Open macOS Notifications settings, choose Claude or Codex, then turn off Play sound."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "NotchPilot 不能直接修改 Claude / Codex 的系统通知声音。打开 macOS 通知设置后，请选择 Claude 或 Codex，并关闭「播放声音」。"
          }
        }
      }
    },
