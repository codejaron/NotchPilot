    "enableSystemMonitorPluginDetail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When off, CPU, memory, network, and other metrics stop sampling and are removed from Notch."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭后停止采样 CPU、内存、网络等指标，并从 Notch 中移除。"
          }
        }
      }
    },
